# Cache control for graduatesalary.co
# Hashed Astro assets are immutable; HTML must always revalidate
# so users see fresh content right after every deploy.

<IfModule mod_headers.c>
  # Hashed, content-addressed assets: cache forever
  <FilesMatch "\.(js|css|woff2|woff|ttf|svg|png|jpg|jpeg|webp|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML: never cache (browser or SiteGround edge)
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    # Tell SiteGround's NGINX dynamic cache to skip this response
    Header set X-Cache-Enabled "False"
  </FilesMatch>

  # Directory index requests (e.g. /blog/, /)
  <FilesMatch "^$|^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set X-Cache-Enabled "False"
  </FilesMatch>
</IfModule>

# Clean URLs: serve /blog/foo/ from /blog/foo/index.html
DirectoryIndex index.html
